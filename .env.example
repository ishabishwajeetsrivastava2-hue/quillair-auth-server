# Copy this file to .env and fill in real values before running.
# NEVER commit the real .env file to git.

PORT=3000
NODE_ENV=development

# Generate strong random values for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_this_with_a_long_random_string
JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_string

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# Postgres connection string. On Render, copy this from your Postgres
# instance's "Internal Database URL" (use the internal one if your auth
# server and database are in the same Render region - it's faster and
# free; the External URL works too but counts toward bandwidth).
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/quillair_auth

# Bootstrap admin - created automatically on first run if no users exist.
# Change the password immediately after first login.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change_me_immediately

# Comma-separated list of allowed origins. Use * only for early local testing.
ALLOWED_ORIGINS=*
